{
  "expo": {
    "name": "Shadow Anki",
    "slug": "shadow-anki",
    "scheme": "shadowanki",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "plugins": [
      "expo-router",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.adaolima.shadowanki"
    }
  }
}
